{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["server/**"]
  },
  "deploy": {
    "startCommand": "cd server && uvicorn main:app --host 0.0.0.0 --port $PORT",
    "healthcheckPath": "/docs",
    "restartPolicyType": "ON_FAILURE"
  }
}
